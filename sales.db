create database sales_db;
USE sales_db;

CREATE TABLE sales (
    OrderID INT PRIMARY KEY,
    Product VARCHAR(50),
    Category VARCHAR(50),
    Price FLOAT,
    Quantity INT,
    City VARCHAR(50),
    Date DATE
);
